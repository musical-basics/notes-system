# Copy to .env and fill in. .env is gitignored — never commit real keys.
# The sync job and enrichment task both load this file.

# Supabase project (the existing one that hosts the Librarian's corpus)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_KEY=YOUR_SERVICE_ROLE_KEY

# Optional: back-date the incremental cursor by this many minutes on every run.
# Idempotent upserts make this free; it avoids missing notes saved on a boundary.
CURSOR_BACKDATE_MINUTES=5

# --- v0b enrichment only (not needed for v0a capture) ---
# ANTHROPIC_API_KEY=sk-ant-...
# Embedding model + dimension MUST mirror the Librarian. See README.
# LIBRARIAN_EMBED_MODEL=text-embedding-3-small
